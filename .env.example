# X → Alpaca Options Bot — Environment Variables
# Copy to .env and fill in. Never commit .env.

# ---- X (Twitter) API ----
X_BEARER_TOKEN=
X_TARGET_ACCOUNT_ID=                          # Numeric account ID, NOT handle

# ---- Anthropic (Claude API for parsing) ----
ANTHROPIC_API_KEY=
# Override the parser model (default: claude-haiku-4-5 — ~3x faster than
# Sonnet on the tweet-extraction schema with no measurable accuracy hit).
# Roll back to claude-sonnet-4-6 here if accuracy regresses.
PARSER_MODEL=

# ---- Alpaca (Paper Only — enforced by assert_paper_mode) ----
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ---- Polygon.io (Greeks and IV data) ----
POLYGON_API_KEY=

# ---- Supabase / Postgres ----
SUPABASE_URL=
SUPABASE_KEY=
DATABASE_URL=                                 # Direct Postgres connection string

# ---- Telegram (alerts) ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Bot tunables (defaults applied if unset) ----
STOP_LOSS_PCT=0.20                            # Initial stop loss below entry
DAILY_LOSS_KILL_PCT=0.03                      # Daily loss kill switch threshold
MAX_CONSECUTIVE_LOSSES=4                      # Consecutive loss pause threshold
MAX_FILL_WAIT_SECONDS=60                      # Order fill timeout
SIGNAL_STALE_SECONDS=180                      # Max age of X post to act on
PRICE_DEVIATION_PCT=0.10                      # Max deviation from posted price

# ---- Operator switches ----
# Set DISABLE_X_STREAM=true to skip the X stream entirely. Useful when your
# X Developer account is rate-limited, out of credits, or not yet wired up.
# The bot keeps running (API + position management + snapshots); just no
# new signals arrive. The x_stream_disconnected kill switch is suppressed.
DISABLE_X_STREAM=

# Set to enable POST /debug/inject-post — pushes a synthetic X post into the
# orchestrator's event queue for end-to-end testing without depending on the
# real X stream. Disabled (503) when unset. Use a random string and treat as
# a credential. Example: `openssl rand -hex 32`
DEBUG_INJECT_TOKEN=
