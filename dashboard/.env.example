# Dashboard build-time env vars. Vite inlines anything prefixed with VITE_.
#
# Local dev: leave VITE_API_BASE empty. Vite's proxy (vite.config.js)
# forwards /healthz, /positions, /signals, /performance, /ws to
# localhost:8000.
#
# Production: set this to your droplet's public URL, e.g.
#   VITE_API_BASE=https://api.x-alpaca-bot.example.com
# or
#   VITE_API_BASE=http://203.0.113.10:8000

VITE_API_BASE=
